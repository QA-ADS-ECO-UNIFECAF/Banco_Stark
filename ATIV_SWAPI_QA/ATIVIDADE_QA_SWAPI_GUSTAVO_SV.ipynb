Parte 3 — Pensando como QA
import requests

# 3.1 Validações básicas
print("3.1 Validações básicas")
url_validacao = "https://swapi.dev/api/people/1/"
response_validacao = requests.get(url_validacao)
dados_validacao = response_validacao.json()

# Validação 1: Verifica o status code da resposta
validacao_1 = response_validacao.status_code == 200
print(f"Validação 1 (Status Code 200): {validacao_1}")

# Validação 2: Verifica se o campo 'name' existe nos dados
validacao_2 = "name" in dados_validacao
print(f"Validação 2 (Campo 'name' existe): {validacao_2}")

# Validação 3: Verifica se o campo 'name' não é nulo/vazio
validacao_3 = dados_validacao.get("name") not in [None, "", "unknown"]
print(f"Validação 3 (Campo 'name' não é nulo/vazio): {validacao_3}")

# Validação 4: Verifica se há dados na resposta (o JSON não está vazio)
validacao_4 = bool(dados_validacao)
print(f"Validação 4 (Dados não vazios): {validacao_4}")

print("\nExplique com suas palavras")
print("O que a validação 1 verifica? Verifica se a requisição foi bem-sucedida, ou seja, se o servidor respondeu corretamente (Status Code 200 OK).")
print("O que a validação 2 verifica? Verifica se um campo esperado (neste caso, 'name') está presente na resposta JSON, garantindo que a estrutura básica está correta.")
print("O que a validação 3 verifica? Verifica se o valor do campo 'name' não é vazio, nulo ou 'unknown', assegurando que o dado retornado é significativo.")
print("O que a validação 4 verifica? Verifica se o corpo da resposta JSON não está vazio, indicando que algum dado foi efetivamente retornado pela API.")

# 3.2 Complete as validações

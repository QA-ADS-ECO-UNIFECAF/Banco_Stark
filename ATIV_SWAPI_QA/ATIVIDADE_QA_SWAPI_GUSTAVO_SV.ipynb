Parte 6 — Mini desafio final
Agora você vai alterar apenas o endpoint da função abaixo e gerar um pequeno resumo.

import requests

def resumo_recurso(url):
    try:
        resposta = requests.get(url)
        resposta.raise_for_status()  # Levanta um HTTPError para 4XX/5XX responses
        dados = resposta.json()

        print(f"\n--- Resumo do Recurso: {url} ---")
        print(f"Status Code: {resposta.status_code}")

        if dados:
            print(f"Nome/Título: {dados.get('name') or dados.get('title', 'N/A')}")
            print(f"Campo que chamou atenção (ex: população): {dados.get('population', 'N/A')}")
            print("Primeiras 3 validações que um QA faria:")
            print(f"(1) Status Code: 200 (Verifica se a requisição foi bem-sucedida)")
            print(f"(2) name/title: '{dados.get('name') or dados.get('title', 'N/A')}' (Verifica se o nome/título está presente e correto)")
            print(f"(3) url: '{dados.get('url', 'N/A')}' (Verifica se a URL do próprio recurso está correta e é a esperada)")
        else:
            print("Nenhum dado retornado no JSON.")

    except requests.exceptions.HTTPError as err:
        print(f"\nErro HTTP para {url}: {err}")
        print(f"Status Code: {resposta.status_code}")
    except requests.exceptions.RequestException as err:
        print(f"\nErro na requisição para {url}: {err}")

# Testando o desafio com o planeta 8 (Naboo)
print("Executando o Mini desafio final")
url_desafio = "https://swapi.dev/api/planets/8/"
resumo_recurso(url_desafio)

print("\nRespostas finais")
print(f"Qual endpoint você testou no desafio? {url_desafio}")
print("Qual foi o status code? 200 (conforme a execução da função acima).")
print("Qual campo chamou mais a sua atenção? Population: 4500000000 (um valor muito alto, interessante para análise). ")
print("Se você fosse QA, quais 3 validações faria nesse recurso?")
print("(1) Status Code: 200 - Para garantir que a comunicação com a API está funcionando.")
print("(2) name: 'Naboo' - Para confirmar que o recurso retornado é realmente o planeta esperado.")
print("(3) gravity: '1 standard' ou population: '4500000000' - Para verificar a consistência e o formato de dados numéricos/importantes, como gravidade ou população.")

print("\n### Conclusão da Atividade")
print("**Conclusão curta do grupo:** As 3 validações mais importantes que identificamos são: verificar o **Status Code** (garante a comunicação), a **existência e correção de campos chave como 'name'** (garante a identificação do recurso) e a **consistência de dados específicos relevantes** (como 'population' ou 'model') que impactam diretamente a funcionalidade ou a informação exibida ao usuário. Essas validações são cruciais para a estabilidade e confiabilidade de qualquer integração com APIs.")


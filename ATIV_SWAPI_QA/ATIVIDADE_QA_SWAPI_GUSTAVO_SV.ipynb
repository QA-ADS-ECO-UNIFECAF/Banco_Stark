print(f"Modelo: {dados_nave_validacao.get('model')}")

# Adicione suas validações aqui
# Validação para Status Code
assert response_nave_validacao.status_code == 200, f"Erro: Status code inesperado! Esperado 200, recebido {response_nave_validacao.status_code}"
print("Validação: Status code é 200. OK.")

# Validação para o nome da nave
assert dados_nave_validacao.get("name") == "Millennium Falcon", f"Erro: Nome da nave inesperado! Esperado 'Millennium Falcon', recebido {dados_nave_validacao.get('name')}"

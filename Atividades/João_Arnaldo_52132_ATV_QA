# =========================================
# SISTEMA BANCÁRIO
# =========================================

class Banco:

    def __init__(self):
        self.contas = {}

    # -----------------------------
    # Criar conta
    # -----------------------------
    def criar_conta(self, titular):

        if titular is None or titular.strip() == "":
            print("Erro: titular inválido.")
            return

        if titular in self.contas:
            print("Erro: conta já existe.")
            return

        self.contas[titular] = {
            "saldo": 0,
            "extrato": []
        }

        print(f"Conta criada para {titular}")


    # -----------------------------
    # Depositar
    # -----------------------------
    def depositar(self, titular, valor):

        if titular not in self.contas:
            print("Erro: conta inexistente.")
            return

        if valor <= 0:
            print("Erro: valor de depósito inválido.")
            return

        self.contas[titular]["saldo"] += valor
        self.contas[titular]["extrato"].append(f"Depósito: +{valor}")

        print(f"Depósito de {valor} realizado em {titular}")


    # -----------------------------
    # Sacar
    # -----------------------------
    def sacar(self, titular, valor):

        if titular not in self.contas:
            print("Erro: conta inexistente.")
            return

        if valor <= 0:
            print("Erro: valor de saque inválido.")
            return

        if valor > self.contas[titular]["saldo"]:
            print("Erro: saldo insuficiente.")
            return

        self.contas[titular]["saldo"] -= valor
        self.contas[titular]["extrato"].append(f"Saque: -{valor}")

        print(f"Saque de {valor} realizado em {titular}")


    # -----------------------------
    # Transferir
    # -----------------------------
    def transferir(self, origem, destino, valor):

        if origem not in self.contas:
            print("Erro: conta de origem inexistente.")
            return

        if destino not in self.contas:
            print("Erro: conta de destino inexistente.")
            return

        if origem == destino:
            print("Erro: não é possível transferir para a mesma conta.")
            return

        if valor <= 0:
            print("Erro: valor de transferência inválido.")
            return

        if valor > self.contas[origem]["saldo"]:
            print("Erro: saldo insuficiente para transferência.")
            return

        self.contas[origem]["saldo"] -= valor
        self.contas[destino]["saldo"] += valor

        self.contas[origem]["extrato"].append(
            f"Transferência enviada: -{valor} para {destino}"
        )

        self.contas[destino]["extrato"].append(
            f"Transferência recebida: +{valor} de {origem}"
        )

        print(f"Transferência de {valor} de {origem} para {destino} realizada")


    # -----------------------------
    # Mostrar saldo
    # -----------------------------
    def saldo_atual(self, titular):

        if titular not in self.contas:
            print("Erro: conta inexistente.")
            return

        saldo = self.contas[titular]["saldo"]
        print(f"Saldo de {titular}: {saldo}")


    # -----------------------------
    # Mostrar extrato
    # -----------------------------
    def mostrar_extrato(self, titular):

        if titular not in self.contas:
            print("Erro: conta inexistente.")
            return

        print(f"\nExtrato da conta {titular}")

        for operacao in self.contas[titular]["extrato"]:
            print(operacao)

        print(f"Saldo atual: {self.contas[titular]['saldo']}")


